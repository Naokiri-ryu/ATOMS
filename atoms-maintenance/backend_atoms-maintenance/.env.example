APP_NAME=ATOMS-Maintenance
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

DB_CONNECTION=pgsql
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=atoms_maintenance
DB_USERNAME=postgres
DB_PASSWORD=

# Rostering DB — READ-ONLY second connection (atoms-rostering source of truth)
ROSTERING_DB_HOST=localhost
ROSTERING_DB_PORT=5432
ROSTERING_DB_DATABASE=atoms_rostering
ROSTERING_DB_USERNAME=postgres
ROSTERING_DB_PASSWORD=

# Rostering API base URL (for HTTP-based integration)
# Port assignments (local dev):
#   atoms-rostering backend  → http://localhost:8001
#   atoms-maintenance backend → http://localhost:8000
#   atoms-maintenance frontend → http://localhost:5173 (Vite default)
#   atoms-rostering frontend  → http://localhost:5174 (run: npm run dev -- --port 5174)
ROSTERING_API_URL=http://localhost:8001
ROSTERING_FRONTEND_URL=http://localhost:5174

# Mock authentication for development
# Set to true to bypass real SSO and use mock users
# Set to false for production SSO integration with atoms-rostering
DEV_MOCK_AUTH=true

# Sanctum configuration
SANCTUM_STATEFUL_DOMAINS=localhost:5173
SESSION_DOMAIN=localhost

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# File storage
FILESYSTEM_DISK=local

# Note: Local developers may set DB_PASSWORD in their own .env file.
# DO NOT commit real credentials here.
